@using CRMSystem.Shared.Entities
@model TaskM

@{
    ViewData["Title"] = "Задача";
    Layout = "_Layout";
}

<style>
    .details-wrapper {
        max-width: 800px;
        margin: 0 auto;
    }

    .details-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .details-title {
        font-size: 22px;
        font-weight: 600;
        color: #111827;
    }

    .badges {
        display: flex;
        gap: 10px;
    }

    .badge {
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-new {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-inprogress {
        background: #fef3c7;
        color: #92400e;
    }

    .status-done {
        background: #dcfce7;
        color: #166534;
    }

    .priority-low {
        background: #e5e7eb;
        color: #374151;
    }

    .priority-medium {
        background: #fde68a;
        color: #92400e;
    }

    .priority-high {
        background: #fecaca;
        color: #991b1b;
    }

    .details-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        margin-bottom: 24px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .info-item {
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 12px;
    }

    .info-label {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 6px;
    }

    .info-value {
        font-size: 15px;
        font-weight: 500;
        color: #111827;
        word-break: break-word;
    }

    .description {
        margin-top: 16px;
    }

    .description-text {
        font-size: 14px;
        color: #374151;
        line-height: 1.6;
        white-space: pre-wrap;
    }

    .details-actions {
        display: flex;
        justify-content: space-between;
    }

    .btn {
        border: none;
        padding: 12px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.2s;
    }

    .btn-primary {
        background: #2563eb;
        color: #ffffff;
    }

        .btn-primary:hover {
            background: #1e40af;
        }

    .btn-secondary {
        background: #e5e7eb;
        color: #374151;
    }

        .btn-secondary:hover {
            background: #d1d5db;
        }
</style>

<div class="details-wrapper">
    <div class="details-header">
        <div class="details-title">
            @Model.Title
        </div>

        <div class="badges">
            @{
                var statusClass = Model.Status switch
                {
                    CRMSystem.Shared.Entities.TaskStatus.New => "badge status-new",
                    CRMSystem.Shared.Entities.TaskStatus.AtWork => "badge status-inprogress",
                    CRMSystem.Shared.Entities.TaskStatus.Completed => "badge status-done",
                    _ => "badge"
                };

                var priorityClass = Model.Priority switch
                {
                    TaskPriority.Low => "badge priority-low",
                    TaskPriority.Medium => "badge priority-medium",
                    TaskPriority.High => "badge priority-high",
                    _ => "badge"
                };
            }

            <span class="@statusClass">@Model.Status</span>
            <span class="@priorityClass">@Model.Priority</span>
        </div>
    </div>

    <div class="details-card">
        <div class="info-grid">
            <div class="info-item">
                <div class="info-label">Клиент</div>
                <div class="info-value">@Model.Customer.Name</div>
            </div>

            <div class="info-item">
                <div class="info-label">Ответственный</div>
                <div class="info-value">@Model.AssignedTo.Name</div>
            </div>

            <div class="info-item">
                <div class="info-label">Срок выполнения</div>
                <div class="info-value">
                    @Model.DueDate.ToString("dd.MM.yyyy")
                </div>
            </div>

            <div class="info-item">
                <div class="info-label">Создано</div>
                <div class="info-value">
                    @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="description">
                <div class="info-label">Описание</div>
                <div class="description-text">
                    @Model.Description
                </div>
            </div>
        }
    </div>

    <div class="details-actions">
        <a asp-action="Index" class="btn btn-secondary">
            Назад
        </a>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            Редактировать
        </a>
    </div>
</div>