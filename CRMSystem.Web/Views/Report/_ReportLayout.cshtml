@{
    Layout = "_Layout";
}

<style>
    .reports-layout {
        display: flex;
        gap: 30px;
        margin-top: 20px;
    }

    .reports-sidebar {
        flex: 0 0 250px;
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        padding: 20px;
        height: fit-content;
        position: sticky;
        top: 100px;
    }

    .reports-sidebar-title {
        color: #333;
        font-size: 18px;
        font-weight: 600;
        padding-bottom: 15px;
        border-bottom: 1px solid #e1e5e9;
        margin-bottom: 15px;
    }

    .reports-menu {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .reports-menu-item {
        padding: 12px 15px;
        border-radius: 8px;
        color: #666;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.3s ease;
        background: #f8f9fa;
        border-left: 3px solid transparent;
    }

    .reports-menu-item:hover {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        color: #667eea;
        border-left-color: #667eea;
        transform: translateX(5px);
    }

    .reports-menu-item.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-left-color: white;
    }

    .reports-content {
        flex: 1;
        min-width: 0;
    }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .reports-layout {
            flex-direction: column;
        }

        .reports-sidebar {
            flex: none;
            width: 100%;
            position: static;
        }
    }
</style>

<div class="reports-layout">
    <aside class="reports-sidebar">
        <div class="reports-sidebar-title">Отчеты</div>
        <nav class="reports-menu">
            @{
                var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
            }
            <a class="reports-menu-item @(currentAction == "Index" ? "active" : "")"
               asp-action="Index" asp-controller="Report">Общая статистика</a>
            <a class="reports-menu-item @(currentAction == "ByStatus" ? "active" : "")"
               asp-action="ByStatus" asp-controller="Report">Отчет по статусам</a>
            <a class="reports-menu-item @(currentAction == "ByPriority" ? "active" : "")"
               asp-action="ByPriority" asp-controller="Report">Отчет по приоритетам</a>
            <a class="reports-menu-item @(currentAction == "ByUsers" ? "active" : "")"
               asp-action="ByUsers" asp-controller="Report">Отчет по пользователям</a>
            <a class="reports-menu-item @(currentAction == "ByCustomers" ? "active" : "")"
               asp-action="ByCustomers" asp-controller="Report">Отчет по клиентам</a>
        </nav>
    </aside>
    <main class="reports-content">
        @RenderBody()
    </main>
</div>

@await RenderSectionAsync("Scripts", required: false)