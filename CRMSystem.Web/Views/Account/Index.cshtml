@{
    Layout = "_Layout";
    ViewData["Title"] = "Личный кабинет";
}

<style>
    .profile-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .profile-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .profile-header h1 {
            color: #333;
            font-size: 32px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .profile-header p {
            color: #666;
            font-size: 16px;
        }

    .profile-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        padding: 40px;
        margin-bottom: 30px;
    }

    .user-avatar-large {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        margin: 0 auto 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 48px;
        font-weight: 600;
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
    }

    .user-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 25px;
        margin-bottom: 30px;
    }

    .info-item {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 10px;
        border-left: 4px solid #667eea;
        transition: all 0.3s ease;
    }

        .info-item:hover {
            background: white;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            transform: translateY(-3px);
        }

    .info-label {
        color: #666;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-value {
        color: #333;
        font-size: 18px;
        font-weight: 600;
    }

    .role-badge {
        display: inline-block;
        padding: 6px 16px;
        background: linear-gradient(135deg, #51cf66 0%, #40c057 100%);
        color: white;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        margin-top: 5px;
    }

        .role-badge.admin {
            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
        }

        .role-badge.moderator {
            background: linear-gradient(135deg, #4dabf7 0%, #339af0 100%);
        }

        .role-badge.user {
            background: linear-gradient(135deg, #51cf66 0%, #40c057 100%);
        }

    .profile-actions {
        display: flex;
        gap: 15px;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid #e1e5e9;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-top: 40px;
    }

    .stat-card {
        background: white;
        padding: 25px;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0 3px 15px rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
        }

    .stat-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        color: #667eea;
        font-size: 24px;
    }

    .stat-value {
        font-size: 32px;
        font-weight: 700;
        color: #333;
        margin-bottom: 5px;
    }

    .stat-label {
        color: #666;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    @@media (max-width: 768px) {
        .profile-card {
            padding: 25px 20px;
        }

        .user-info-grid {
            grid-template-columns: 1fr;
        }

        .profile-actions {
            flex-direction: column;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }
    }

    .last-login {
        text-align: center;
        color: #666;
        font-size: 14px;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #e1e5e9;
    }

    .status-indicator {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 5px 12px;
        background: #f8f9fa;
        border-radius: 15px;
        font-size: 13px;
        color: #666;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background: #51cf66;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }
</style>

<div class="profile-container">
    <div class="profile-header">
        <h1>Личный кабинет</h1>
        <p>Управление вашим профилем и настройками</p>
    </div>

    <div class="profile-card">
        <!-- Аватар пользователя -->
        <div class="user-avatar-large">
            @if (ViewBag.Name != null)
            {
                @ViewBag.Name.ToString().Substring(0, 1).ToUpper()
            }
            else
            {
                @:U
            }
        </div>

        <!-- Индикатор статуса -->
        <div style="text-align: center; margin-bottom: 30px;">
            <div class="status-indicator">
                <span class="status-dot"></span>
                <span>Активен</span>
            </div>
        </div>

        <!-- Основная информация -->
        <div class="user-info-grid">
            <div class="info-item">
                <div class="info-label">Полное имя</div>
                <div class="info-value">@ViewBag.Name</div>
            </div>

            <div class="info-item">
                <div class="info-label">Электронная почта</div>
                <div class="info-value">@ViewBag.Email</div>
            </div>

            <div class="info-item">
                <div class="info-label">Роль в системе</div>
                <div class="info-value">
                    @ViewBag.Role
                    <span class="role-badge @(ViewBag.Role?.ToString().ToLower())">@ViewBag.Role</span>
                </div>
            </div>

            <!--
            <div class="info-item">
                <div class="info-label">Дата регистрации</div>
                <div class="info-value">@DateTime.Now.AddMonths(-3).ToString("dd MMMM yyyy")</div>
            </div>
            -->
        </div>

        <!-- Статистика (пример) -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">📋</div>
                <div class="stat-value">@((int)(ViewBag.Name?.ToString().Length ?? 10) * 2)</div>
                <div class="stat-label">Задач выполнено</div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">👥</div>
                <div class="stat-value">@((int)(ViewBag.Name?.ToString().Length ?? 10) * 3)</div>
                <div class="stat-label">Клиентов</div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">⭐</div>
                <div class="stat-value">@((int)(ViewBag.Name?.ToString().Length ?? 10))</div>
                <div class="stat-label">Рейтинг</div>
            </div>
        </div>

        <!-- Действия -->
        <!--<div class="profile-actions">
            <a href="/Profile/Edit" class="btn btn-primary" style="flex: 1;">
                Редактировать профиль
            </a>
            <a href="/Profile/Security" class="btn btn-secondary" style="flex: 1;">
                Безопасность
            </a>
            <a href="/Profile/Settings" class="btn btn-secondary" style="flex: 1;">
                Настройки
            </a>
        </div>
        -->
        <!-- Время последнего входа -->
        <div class="last-login">
            Последний вход: @DateTime.Now.AddHours(-2).ToString("dd.MM.yyyy HH:mm")
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Анимация появления элементов
        const animateElements = document.querySelectorAll('.info-item, .stat-card');
        animateElements.forEach((element, index) => {
            element.style.opacity = '0';
            element.style.transform = 'translateY(20px)';

            setTimeout(() => {
                element.style.transition = 'all 0.5s ease';
                element.style.opacity = '1';
                element.style.transform = 'translateY(0)';
            }, 100 * index);
        });

        // Динамическое обновление времени активности
        function updateActiveTime() {
            const now = new Date();
            const options = {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: false
            };
            document.querySelector('.last-login').innerHTML =
                `Текущее время: ${now.toLocaleTimeString('ru-RU', options)} | Активен`;
        }

        // Обновляем время каждую секунду
        setInterval(updateActiveTime, 1000);
        updateActiveTime(); // Инициализация

        // Обработчик для кнопок действий
        const actionButtons = document.querySelectorAll('.btn');
        actionButtons.forEach(button => {
            button.addEventListener('click', function(e) {
                // Анимация нажатия
                this.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    this.style.transform = '';
                }, 150);
            });
        });
    });
</script>